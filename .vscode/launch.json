{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch NestJS Backend (Debug Mode)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/backend",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "start:debug"
            ],
            "console": "integratedTerminal",
            "restart": true,
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/backend/dist/**/*.js"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Attach to NestJS Backend",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "restart": true,
            "cwd": "${workspaceFolder}/backend",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/backend/dist/**/*.js"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Launch Angular Frontend (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:4200",
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMaps": true
        }
    ],
    "compounds": [
        {
            "name": "Debug Full Stack (Backend + Frontend)",
            "configurations": [
                "Launch NestJS Backend (Debug Mode)",
                "Launch Angular Frontend (Chrome)"
            ]
        }
    ]
}