# Copy this file to backend/.env and fill in the provider you want. backend/.env
# is gitignored. Vision (screenshot -> team) is the only feature that needs a
# model; everything else runs without any of these. If nothing is set, the
# screenshot import simply returns 503 and the rest of the app works normally.

# Which provider reads team screenshots: gemini | openai | ollama
# Leave blank to auto-detect (uses the OpenAI-compatible client if OPENAI_BASE_URL
# or OPENAI_API_KEY is set, otherwise Gemini).
VISION_PROVIDER=

# --- Option A: Google Gemini (cloud, free tier) -----------------------------
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the model (defaults to gemini-2.0-flash).
# GEMINI_VISION_MODEL=gemini-2.0-flash

# --- Option B: OpenAI-compatible API ----------------------------------------
# Works with OpenAI cloud AND local servers (Ollama, LM Studio, OpenRouter).
#
# OpenAI cloud:
#   VISION_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_VISION_MODEL=gpt-4o-mini
#
# Ollama (local, free, offline — no API key needed):
#   1) Install Ollama, run `ollama serve`
#   2) `ollama pull llava`        (any vision model: llava, llama3.2-vision, ...)
#   3) set the three lines below
#   VISION_PROVIDER=ollama
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_VISION_MODEL=llava
#   OPENAI_API_KEY=ollama         (any non-empty value)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_VISION_MODEL=gpt-4o-mini
